# =============================================================================
# E*TRADE Stock Monitor - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- E*TRADE API Credentials ---
# Get these from https://developer.etrade.com/getting-started
ETRADE_CONSUMER_KEY=your_consumer_key_here
ETRADE_CONSUMER_SECRET=your_consumer_secret_here
# Set to "sandbox" for testing, "live" for real data
ETRADE_ENVIRONMENT=sandbox

# --- LLM Backend ---
# Choose: "gemini" (FREE, recommended), "claude" (paid), "fallback" (no API)
LLM_BACKEND=gemini

# --- Google Gemini (FREE - no credit card needed) ---
# Get your free API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic Claude (PAID - optional) ---
# Get your key from https://console.anthropic.com/
# Only needed if LLM_BACKEND=claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
# Daily spending cap (USD) - stops calling Claude API when reached
DAILY_SPEND_LIMIT_USD=0.50

# --- Email Settings ---
# Choose: "gmail_api" (OAuth2, recommended) or "smtp" (needs App Password)
EMAIL_BACKEND=gmail_api

# Gmail address (used by both backends)
GMAIL_ADDRESS=your_email@gmail.com
# Recipient email (can be same as sender)
RECIPIENT_EMAIL=your_email@gmail.com

# Gmail API setup (if EMAIL_BACKEND=gmail_api):
#   1. Go to https://console.cloud.google.com/
#   2. Create project → Enable "Gmail API"
#   3. Create OAuth 2.0 credentials → Application type: "Desktop app"
#   4. Download JSON → save as credentials.json in project root
#   5. First run opens browser to authorize — only needed once

# SMTP App Password (only if EMAIL_BACKEND=smtp):
GMAIL_APP_PASSWORD=

# --- Schedule (24-hour format, US Eastern Time) ---
PRE_MARKET_HOUR=8
PRE_MARKET_MINUTE=30
POST_MARKET_HOUR=16
POST_MARKET_MINUTE=30
TIMEZONE=US/Eastern

# --- News Settings ---
# Max news articles to fetch per stock
MAX_NEWS_PER_STOCK=20
# Number of top news to include in email
TOP_NEWS_COUNT=5
